# Brigata Studio — STANDALONE / SELF-HOST configuration template
# ---------------------------------------------------------------------------
# Copy to `.env` on a self-hosted install and fill in the values below. This is
# the SINGLE-TENANT mode: one admin, one workspace, one Standard agent, no
# Google OAuth, no Stripe billing, no Pro-tier VPS provisioning.
#
# When STANDALONE_MODE is unset/off, the server runs as the normal multi-tenant
# cloud build and ignores everything specific to this file.
# ---------------------------------------------------------------------------

# Turn on self-host mode. Accepts 1 | true | on | yes.
STANDALONE_MODE=1

# Postgres connection string for the local/self-hosted database.
DATABASE_URL=postgres://brigata:CHANGE_ME@localhost:5432/brigata

# Bring-your-own Anthropic key. Self-host agents run in-process on this key.
# Accepts an API key (sk-ant-api03-...) or an OAuth subscription token
# (sk-ant-oat01-...). Users can also set their own key later in the UI.
ANTHROPIC_API_KEY=sk-ant-api03-CHANGE_ME

# Shared password for the single admin login (POST /api/auth/standalone-login).
# Choose a long random value. Login is refused (403) if this is blank.
STANDALONE_ADMIN_PASSWORD=CHANGE_ME_to_a_long_random_password

# Public base URL the app is served from. Used for redirects.
APP_BASE_URL=http://localhost:3030

# Session cookie domain. Leave BLANK for a host-only cookie (correct for
# localhost / plain http). Set to your hostname only when serving over HTTPS on
# a real domain (e.g. studio.example.com) — the session cookie is then marked
# Secure and scoped to that domain.
SESSION_COOKIE_DOMAIN=

# Port the server listens on.
PORT=3030
